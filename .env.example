# NASA API — get a key at https://api.nasa.gov/
# Comma-separated for multi-key rate limit rotation
NASA_API_KEYS=DEMO_KEY

# Date to begin historical backfill from
START_DATE=2015-01-01

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=neows_ingest

# TimescaleDB
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=neo_db
DB_USER=neo_user
DB_PASSWORD=neo_password
