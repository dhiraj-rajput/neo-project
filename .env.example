# API Configuration
DATABASE_URL=postgres://neo_user:neo_password@timescaledb:5432/neo_db
NASA_API_KEYS=KEY1,KEY2,KEY3 # Comma-separated list for multi-agency ingestion

# Services
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=neo_db
DB_USER=neo_user
DB_PASSWORD=neo_password

# Grafana
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Pipeline Configuration
START_DATE=1900-01-01
PRODUCER_POLL_INTERVAL_HOURS=24
AGENCY_NOT_FOUND_HOLD_DAYS=30
AGENCY_BATCH_LIMIT=2000
AGENCY_CONCURRENCY=25
AGENCY_SENTRY_SEED_LIMIT=500
NEOWS_NOT_FOUND_HOLD_DAYS=30

# Agency API Endpoints (Research Grade)
JPL_SBDB_URL=https://ssd-api.jpl.nasa.gov/sbdb.api
JPL_CAD_URL=https://ssd-api.jpl.nasa.gov/cad.api
JPL_SENTRY_URL=https://ssd-api.jpl.nasa.gov/sentry.api
ESA_NEOCC_URL=https://neo.ssa.esa.int/
IAU_MPC_URL=https://minorplanetcenter.net/db_search/
